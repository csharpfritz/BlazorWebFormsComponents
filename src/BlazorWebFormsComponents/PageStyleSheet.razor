@* 
    PageStyleSheet - Dynamically loads and unloads CSS stylesheets.
    
    Provides a Web Forms-like pattern for page-specific CSS:
    Original: <asp:Content ContentPlaceHolderID="head"><link href="CSS/page.css" rel="stylesheet"/></asp:Content>
    Blazor:   <PageStyleSheet Href="CSS/page.css" />
    
    Render Mode Behavior:
    - Static SSR: Renders a <link> tag directly into the HTML stream (no unload)
    - Prerendering: Renders <link> tag during prerender, then JS manages after hydration
    - InteractiveServer/WebAssembly: Uses JS interop to load/unload CSS dynamically
*@

@inherits ComponentBase
@implements IAsyncDisposable

@* For non-interactive renders, emit a static <link> tag directly into the HTML *@
@if (!string.IsNullOrEmpty(Href) && !RendererInfo.IsInteractive)
{
    <link rel="stylesheet" href="@Href" id="@GetLinkId()" 
          media="@Media" integrity="@Integrity" crossorigin="@CrossOrigin" />
}

@code {
    // Interactive rendering handled through JS interop
}
