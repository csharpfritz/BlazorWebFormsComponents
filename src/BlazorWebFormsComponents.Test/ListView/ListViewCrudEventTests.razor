	// ═════════════════════════════════════════════════════════════════
	// CANCEL: ItemCanceling
	// ═════════════════════════════════════════════════════════════════

	[Fact]
	public void HandleCommand_Cancel_InEditMode_SetsCancelModeToEdit()
	{
		int editIdx = 1;
		var cut = Render(@<ListView Items="Widget.SimpleWidgetList"
						ItemType="Widget"
						EditIndex="editIdx"
						ItemCanceling="OnCanceling"
						Context="Item"
						@ref="theListView">
			<ItemTemplate><span>@Item.Name</span></ItemTemplate>
			<EditItemTemplate><input value="@Item.Name" /></EditItemTemplate>
		</ListView>);

		cut.InvokeAsync(() => theListView.HandleCommand("Cancel", null, 1));

		_cancelingArgs.ShouldNotBeNull();
		_cancelingArgs.CancelMode.ShouldBe(ListViewCancelMode.CancelingEdit);
		_cancelingArgs.ItemIndex.ShouldBe(1);
		theListView.EditIndex.ShouldBe(-1);
	}

	[Fact]
	public void HandleCommand_Cancel_InInsertMode_SetsCancelModeToInsert()
	{
		InsertItemPosition pos = InsertItemPosition.FirstItem;
		var cut = Render(@<ListView Items="Widget.SimpleWidgetList"
						ItemType="Widget"
						InsertItemPosition="pos"
						ItemCanceling="OnCanceling"
						Context="Item"
						@ref="theListView">
			<ItemTemplate><span>@Item.Name</span></ItemTemplate>
			<InsertItemTemplate><div>Insert</div></InsertItemTemplate>
		</ListView>);

		cut.InvokeAsync(() => theListView.HandleCommand("Cancel", null, 0));

		_cancelingArgs.ShouldNotBeNull();
		_cancelingArgs.CancelMode.ShouldBe(ListViewCancelMode.CancelingInsert);
	}

	[Fact]
	public void HandleCommand_Cancel_Cancellation_PreventsEditIndexReset()
	{
		int editIdx = 2;
		var cut = Render(@<ListView Items="Widget.SimpleWidgetList"
						ItemType="Widget"
						EditIndex="editIdx"
						ItemCanceling="OnCancelingCancel"
						Context="Item"
						@ref="theListView">
			<ItemTemplate><span>@Item.Name</span></ItemTemplate>
			<EditItemTemplate><input value="@Item.Name" /></EditItemTemplate>
		</ListView>);

		cut.InvokeAsync(() => theListView.HandleCommand("Cancel", null, 2));

		_cancelingArgs.ShouldNotBeNull();
		_cancelingArgs.Cancel.ShouldBeTrue();
		// EditIndex should remain since the cancel was vetoed
		theListView.EditIndex.ShouldNotBe(-1);
	}

