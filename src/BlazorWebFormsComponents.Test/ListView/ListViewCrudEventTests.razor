	[Fact]
	public void DataBound_FiresAfterAllItemsRendered()
	{
		var cut = Render(@<ListView Items="Widget.SimpleWidgetList"
						ItemType="Widget"
						OnDataBound="OnDataBound"
						OnItemDataBound="OnItemDataBound"
