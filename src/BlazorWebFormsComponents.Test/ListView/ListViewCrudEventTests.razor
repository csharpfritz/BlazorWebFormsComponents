			<ItemTemplate><span>@Item.Name</span></ItemTemplate>
		</ListView>);

		cut.InvokeAsync(() => theListView.HandleCommand("Update", null, 3));

		_updatingArgs.ShouldNotBeNull();
		_updatingArgs.ItemIndex.ShouldBe(3);
	}

