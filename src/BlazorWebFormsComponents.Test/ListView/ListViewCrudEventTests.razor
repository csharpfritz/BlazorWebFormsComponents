	[Fact]
	public void LayoutCreated_DoesNotFireWhenItemsEmpty()
	{
		Widget[] emptyItems = Array.Empty<Widget>();
		var cut = Render(@<ListView Items="emptyItems"
						ItemType="Widget"
						OnLayoutCreated="OnLayoutCreated"
						Context="Item">
