@inherits BlazorWebFormsTestContext
@using Shouldly

@code {

	[Fact]
	public void CheckBox_WithText_HasSpanWrapper()
	{
		// WebForms CheckBox with text wraps <input> + <label> in a <span>
		var cut = Render(@<CheckBox Text="Accept terms" />);

		cut.Find("span").ShouldNotBeNull();
		cut.Find("span input[type='checkbox']").ShouldNotBeNull();
		cut.Find("span label").ShouldNotBeNull();
	}

	[Fact]
	public void CheckBox_WithoutText_NoSpanWrapper()
	{
		// WebForms CheckBox without text renders just <input>, no <span> wrapper
		var cut = Render(@<CheckBox />);

		Should.Throw<Bunit.ElementNotFoundException>(() => cut.Find("span"));
		cut.Find("input[type='checkbox']").ShouldNotBeNull();
	}

}
