@page "/Courses"
@rendermode InteractiveServer
<HeadContent>
    <link href="ContosoUniversity/CSS/CSS_Courses.css" rel="stylesheet" />
    <script src="ContosoUniversity/JQuery/JQuery_Courses.js"></script>
</HeadContent>
<ScriptManager></ScriptManager>
<UpdatePanel>
    <ContentTemplate>
        <div id="dropList">
            <h1 id="hdrCourse">Select Course</h1>
            <DropDownList TItem="Department" ID="drpDepartments" Items="_departments"
                DataTextField="DepartmentName" DataValueField="DepartmentID"></DropDownList>
            <Button ID="btnSearchCourse" Text="Search Courses" OnClick="btnSearchCourse_Click"></Button>
            <br />
            <br />
            <GridView ItemType="Cours" ID="grvCourses" AllowPaging="true" DataKeyNames="CourseID"
                PageSize="10" AutoGenerateColumns="false" Items="_courses"
                EmptyDataText="Choose Department To Display Courses">
                <Columns>
                    <BoundField ItemType="Cours" DataField="CourseID" HeaderText="ID" />
                    <BoundField ItemType="Cours" DataField="CourseName" HeaderText="Course Name" />
                    <BoundField ItemType="Cours" DataField="StudentsMax" HeaderText="Max Capacity" />
                </Columns>
            </GridView>
        </div>
        <div id="autoComplete">
            <h1 id="crsByName">Courses By Name</h1>
            <TextBox ID="txtCourse" placeholder="Search Course..."></TextBox>
            <Button ID="search" Text="Search" OnClick="search_Click"></Button>
            <br />
            <br />
            <DetailsView ItemType="Cours" ID="dtlCourses" CssClass="details"
                DataItem="_selectedCourse" AutoGenerateRows="true">
            </DetailsView>
        </div>
    </ContentTemplate>
</UpdatePanel>
