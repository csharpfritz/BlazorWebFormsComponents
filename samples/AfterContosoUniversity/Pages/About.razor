@page "/ContosoUniversity/About"
@page "/About"
@rendermode InteractiveServer
<HeadContent>
     <link href="CSS/CSS_About.css" rel="stylesheet" />
</HeadContent>
<div id="header">
    <h1>Students Body Statistics</h1>
</div>
<div id="grv">
    <GridView 
        ItemType="EnrollmentStat"
        Items="_stats"
        CssClass="grid" 
        AutoGenerateColumns="false" 
        EmptyDataText="There are no records to display"
        CellPadding="4">
        <Columns>
            <BoundField DataField="EnrollmentDate" HeaderText="Enrollment Date" />
            <BoundField DataField="StudentCount" HeaderText="Students" />
        </Columns>
    </GridView>
</div>

