@page "/ContosoUniversity/Instructors"
@page "/Instructors"
@rendermode InteractiveServer
<HeadContent>
    <link href="CSS/Instructors_CSS.css" rel="stylesheet" />
</HeadContent>
<ScriptManager></ScriptManager>
<UpdatePanel>
    <ContentTemplate>
        <div id="grv">
            <h1 id="hdr">Our Instructors</h1>
            <GridView 
                ItemType="Instructor"
                Items="_instructors"
                AutoGenerateColumns="false"
                AllowSorting="true"
                CssClass="grv" 
                ID="grvInstructors"
                EmptyDataText="There are no records to display">
                <Columns>
                    <BoundField DataField="InstructorID" HeaderText="Instructor ID" />
                    <BoundField DataField="FirstName" HeaderText="First Name" />
                    <BoundField DataField="LastName" HeaderText="Last Name" />
                    <BoundField DataField="Email" HeaderText="Email" />
                </Columns>
            </GridView>
        </div>
    </ContentTemplate>
</UpdatePanel>

