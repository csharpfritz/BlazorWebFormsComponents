@page "/Courses"
@rendermode InteractiveServer

<PageStyleSheet Href="CSS/CSS_Courses.css" />

<div id="dropList">
    <h1 id="hdrCourse">Select Course</h1>
    <DropDownList TItem="Department" ID="drpDepartments" Items="_departments" 
        DataTextField="DepartmentName" DataValueField="DepartmentID" @bind-SelectedValue="_selectedDepartmentId" />
    <Button ID="btnSearchCourse" Text="Search Courses" OnClick="btnSearchCourse_Click" />
    <br />
    <br />
    <GridView TItem="Cours" ID="grvCourses" Items="_courses" AllowPaging="true" DataKeyNames="CourseID"
        PageSize="5" AutoGenerateColumns="false"
        OnPageIndexChanging="grvCourses_PageIndexChanging"
        EmptyDataText="Choose Department To Display Courses">
        <Columns>
            <BoundField DataField="CourseID" HeaderText="ID" />
            <BoundField DataField="CourseName" HeaderText="Course Name" />
            <BoundField DataField="StudentsMax" HeaderText="Max Capacity" />
        </Columns>
    </GridView>
</div>
<div id="autoComplete">
    <h1 id="crsByName">Courses By Name</h1>
    <TextBox ID="txtCourse" @bind-Text="_searchText" placeholder="Search Course..." />
    <Button ID="search" Text="Search" OnClick="search_Click" />
    <br />
    <br />
    @* ajaxToolkit:AutoCompleteExtender removed - use native HTML datalist or implement JS *@
    <DetailsView TItem="Cours" ID="dtlCourses" Items="@(_selectedCourse != null ? new[] { _selectedCourse } : Array.Empty<Cours>())" 
        AutoGenerateRows="true" CssClass="details" />
</div>



