@page "/Courses"
@page "/Courses.aspx"
<HeadContent>
    <link href="CSS/CSS_Courses.css" rel="stylesheet" />
    <script src="JQuery/JQuery_Courses.js"></script>
</HeadContent>
<ScriptManager></ScriptManager>
    <UpdatePanel>
        <ContentTemplate>
            <div id="dropList">
                <h1 id="hdrCourse">Select Course</h1>
                <select @bind="@_selectedDepartmentId">
                    <option value="0">-- Select Department --</option>
                    @foreach (var dept in _departments)
                    {
                        <option value="@dept.DepartmentID">@dept.DepartmentName</option>
                    }
                </select>
                <Button ID="btnSearchCourse" Text="Search Courses" OnClick="@btnSearchCourse_Click"></Button>
                <br />
                <br />
                <GridView ItemType="Cours" ID="grvCourses" Items="@_courses" AllowPaging="true" DataKeyNames="CourseID"
                    PageSize="5" AutoGenerateColumns="false"
                    EmptyDataText="Choose Department To Display Courses">
                    <Columns>
                        <BoundField ItemType="Cours" DataField="CourseID" HeaderText="ID" />
                        <BoundField ItemType="Cours" DataField="CourseName" HeaderText="Course Name" />
                        <BoundField ItemType="Cours" DataField="StudentsMax" HeaderText="Max Capacity" />
                    </Columns>
                </GridView>
            </div>
            <div id="autoComplete">
                <h1 id="crsByName">Courses By Name</h1>
                <TextBox ID="txtCourse" @bind-Text="@_searchText" placeholder="Search Course..."></TextBox>
                <Button ID="search" Text="Search" OnClick="@search_Click"></Button>
                <br />
                <br />
                @* AutoCompleteExtender removed - not available in BWFC *@
                @if (_selectedCourse != null)
                {
                <DetailsView ItemType="Cours" ID="dtlCourses" Item="@_selectedCourse" AutoGenerateRows="true" CssClass="details">
                </DetailsView>
                }
            </div>
        </ContentTemplate>         
    </UpdatePanel>


