@page "/ShoppingCart"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ProductContext> DbFactory
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Shopping Cart</PageTitle>
<div id="ShoppingCartTitle" class="ContentHead"><h1>Shopping Cart</h1></div>

@if (_cartItems == null || !_cartItems.Any())
{
    <p>Your shopping cart is empty.</p>
}
else
{
    <GridView ItemType="CartItem" Items="_cartItems" AutoGenerateColumns="false"
              ShowFooter="true" GridLines="GridLines.Vertical" CellPadding="4"
              CssClass="table table-striped table-bordered">
        <Columns>
            <BoundField ItemType="CartItem" DataField="ProductId" HeaderText="ID" />
            <BoundField ItemType="CartItem" DataField="Product.ProductName" HeaderText="Name" />
            <BoundField ItemType="CartItem" DataField="Product.UnitPrice" HeaderText="Price (each)" DataFormatString="{0:c}" />
            <TemplateField ItemType="CartItem" HeaderText="Quantity">
                <ItemTemplate Context="Item">
                    <TextBox Width="40" Text="@Item.Quantity.ToString()" />
                </ItemTemplate>
            </TemplateField>
            <TemplateField ItemType="CartItem" HeaderText="Item Total">
                <ItemTemplate Context="Item">
                    @($"{Item.Quantity * (Item.Product?.UnitPrice ?? 0):c}")
                </ItemTemplate>
            </TemplateField>
            <TemplateField ItemType="CartItem" HeaderText="Remove Item">
                <ItemTemplate Context="Item">
                    <CheckBox />
                </ItemTemplate>
            </TemplateField>
        </Columns>
    </GridView>

    <div>
        <p></p>
        <strong>
            <Label Text="Order Total: " />
            <Label Text="@($"{_total:c}")" />
        </strong>
    </div>
    <br />
    <table>
        <tr>
            <td>
                <Button Text="Update" OnClick="UpdateBtn_Click" />
            </td>
            <td>
                <a href="/Checkout/CheckoutStart" onclick="window.location.href=this.href;return false;">
                    <img src="https://www.paypal.com/en_US/i/btn/btn_xpressCheckout.gif"
                         width="145" alt="Check out with PayPal" style="background-color:transparent;border:0;" />
                </a>
            </td>
        </tr>
    </table>
}

@code {
    private List<CartItem> _cartItems = new();
    private double _total;

    protected override async Task OnInitializedAsync()
    {
        var cartId = HttpContextAccessor.HttpContext?.Session.GetString("CartId") ?? "";
        if (string.IsNullOrEmpty(cartId)) return;

        using var db = DbFactory.CreateDbContext();
        _cartItems = await db.ShoppingCartItems
            .Where(c => c.CartId == cartId)
            .Include(c => c.Product)
            .ToListAsync();

        _total = _cartItems.Sum(c => (c.Product?.UnitPrice ?? 0) * c.Quantity);
    }

    private void UpdateBtn_Click()
    {
        // TODO: Implement cart update logic
    }
}
